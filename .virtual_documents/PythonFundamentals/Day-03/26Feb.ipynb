s = input("Enter a string: ")
# Split into words, reverse each word, then join them back with spaces
result = " ".join([word[::-1] for word in s.split()])
print(result)



## WITHOUT ANY FUCNCTION 

s = input("Enter a string: ")
lastspaceAt = -1

for i in range(len(s)):
    if s[i] == " ":
        j = i - 1
        while (j > lastspaceAt):
            # Change s[i] to s[j] to print the characters of the word
            print(s[j], end="")
            j = j - 1
        lastspaceAt = i
        print(" ", end="")

# Printing the last word
k = len(s) - 1
while k > lastspaceAt:
    print(s[k], end="")
    k = k - 1





number=int(input("Enter the number :"))
for i in range(2,number):
    if number%i==0:
        print(f"given number {number} is not a prime number")
        break
else:
    print("Given number {number} is a prime number")



